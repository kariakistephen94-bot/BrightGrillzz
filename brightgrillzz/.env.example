# Copy to .env.local and fill in. Never commit .env.local.

# --- Paystack (dashboard.paystack.com → Settings → API Keys) ---------------
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_SECRET_KEY=sk_test_xxx

# --- Supabase (Project Settings → API) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Cloudinary (cloudinary.com → Dashboard) --------------------------------
# Images + short videos are uploaded SIGNED, straight from the browser: the
# server mints a signature (/api/media/sign) with the API key + secret, which
# never reach the client. The cloud name is public and gates the upload UI.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- Resend email (resend.com → API Keys) ----------------------------------
RESEND_API_KEY=re_xxx
EMAIL_FROM=BrightGrillzz <onboarding@resend.dev>
ORDER_NOTIFICATION_EMAIL=Brightgrillzzglobal@gmail.com
